FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-structuring.txt .
RUN pip install --no-cache-dir -r requirements-structuring.txt

COPY . .

ENV PYTHONPATH=/app

CMD ["python", "-m", "src.structuring.main"]
